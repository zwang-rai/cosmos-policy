# Using your working codebase's base image
FROM nvidia/cuda:12.8.1-cudnn-devel-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive

# --- Ray Cluster / Distributed GPU Environment Variables (From File 1) ---
ENV CUDA_HOME=/usr/local/cuda
ENV PATH=/usr/local/cuda/bin:$PATH
ENV LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH

# --- System Dependencies ---
RUN --mount=type=cache,target=/var/cache/apt \
    --mount=type=cache,target=/var/lib/apt \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        # 1. Your Codebase Dependencies (From File 2)
        build-essential \
        cmake \
        curl \
        ffmpeg \
        git \
        git-lfs \
        gosu \
        libgl1 \
        libegl1-mesa-dev \
        libgl1-mesa-dri \
        libglib2.0-0 \
        sudo \
        tree \
        wget \
        # 2. Ray Cluster Networking & Python Dependencies (From File 1)
        python3 \
        python3-pip \
        python3-venv \
        python-is-python3 \
        libibverbs1 \       
        ibverbs-providers \ 
        ibverbs-utils \     
    && ldconfig \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# --- Cloud Cluster CLI (From File 1, optional but needed if Ray is on GCP) ---
RUN echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] http://packages.cloud.google.com/apt cloud-sdk main" \
    > /etc/apt/sources.list.d/google-cloud-sdk.list && \
    curl https://packages.cloud.google.com/apt/doc/apt-key.gpg | apt-key --keyring /usr/share/keyrings/cloud.google.gpg add - && \
    apt-get update && apt-get install -y --no-install-recommends google-cloud-cli && \
    rm -rf /var/lib/apt/lists/*

# --- Tooling (From File 2) ---
# Install uv
COPY --from=ghcr.io/astral-sh/uv:0.8.12 /uv /uvx /usr/local/bin/

# Install just
RUN curl --proto '=https' --tlsv1.2 -sSf https://just.systems/install.sh | bash -s -- --to /usr/local/bin --tag 1.42.4

# --- Python & Ray Initialization ---
# Upgrade pip utilities globally using uv (bypasses Ubuntu 24.04 PEP 668 restrictions safely)
RUN uv pip install --system pip setuptools wheel

# Ensure the Ray CLI is available globally for cluster orchestration
# (If your cosmos-policy handles installing Ray via 'just' or 'uv.lock' later, you can remove this)
RUN uv pip install --system ray[default]

# --- Entrypoint (From File 2) ---
COPY --chown=root:root --chmod=0755 entrypoint.sh /usr/local/bin/cosmos-policy-entrypoint
# ENTRYPOINT ["/usr/local/bin/cosmos-policy-entrypoint"]

CMD ["/bin/bash"]